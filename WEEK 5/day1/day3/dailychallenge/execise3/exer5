// Base interface with readonly and optional properties
interface Product {
    readonly name: string;      // Immutable
    price: number;              // Mutable
    discount?: number;          // Optional (percentage 0-1)
}

// Extended interface
interface Electronics extends Product {
    warrantyPeriod: number;     // Months
}

// Class implementing the extended interface
class Smartphone implements Electronics {
    readonly name: string;
    price: number;
    discount?: number;
    warrantyPeriod: number;
    brand: string;

    constructor(name: string, price: number, brand: string, warranty: number, discount?: number) {
        this.name = name;
        this.price = price;
        this.brand = brand;
        this.warrantyPeriod = warranty;
        this.discount = discount;
    }

    // Calculate price after discount
    getFinalPrice(): number {
        if (this.discount && this.discount > 0 && this.discount <= 1) {
            return this.price * (1 - this.discount);
        }
        return this.price;
    }

    getProductInfo(): string {
        const discountInfo = this.discount ? `${(this.discount * 100).toFixed(0)}% off` : "No discount";
        return `${this.brand} ${this.name} - Final Price: $${this.getFinalPrice().toFixed(2)} (${discountInfo}), Warranty: ${this.warrantyPeriod} months`;
    }

    applyDiscount(discount: number): void {
        this.discount = discount;
    }

    updatePrice(newPrice: number): void {
        this.price = newPrice;
    }
}

