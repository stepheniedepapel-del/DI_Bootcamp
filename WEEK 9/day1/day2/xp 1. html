<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Todo List with Redux Toolkit</title>
    
    <!-- React & ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    
    <!-- Redux Toolkit (UMD) -->
    <script src="https://unpkg.com/@reduxjs/toolkit@1.9.5/dist/redux-toolkit.umd.js"></script>
    <script src="https://unpkg.com/react-redux@8.1.3/dist/react-redux.min.js"></script>
    
    <!-- Babel for JSX -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        
        .todo-item {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .todo-item:hover {
            transform: translateX(4px);
        }
        
        .todo-item.completed .todo-text {
            text-decoration: line-through;
            color: #9ca3af;
        }
        
        .checkbox-custom {
            appearance: none;
            width: 22px;
            height: 22px;
            border: 2px solid #d1d5db;
            border-radius: 6px;
            cursor: pointer;
            position: relative;
            transition: all 0.2s;
        }
        
        .checkbox-custom:checked {
            background-color: #10b981;
            border-color: #10b981;
        }
        
        .checkbox-custom:checked::after {
            content: '✓';
            position: absolute;
            color: white;
            font-size: 14px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        
        .slide-in {
            animation: slideIn 0.3s ease-out;
        }
        
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .fade-out {
            animation: fadeOut 0.3s ease-out forwards;
        }
        
        @keyframes fadeOut {
            to { opacity: 0; transform: translateX(20px); }
        }
        
        .filter-btn.active {
            background-color: #4f46e5;
            color: white;
        }
        
        .progress-bar {
            transition: width 0.5s ease-out;
        }
    </style>
</head>
<body class="p-4 md:p-8">

    <div id="root"></div>

    <script type="text/babel">
        const { Provider, useSelector, useDispatch } = ReactRedux;
        const { configureStore, createSlice } = window.RTK;
        const { useState, useRef, useEffect } = React;

        // ==========================================
        // STEP 1: CREATE REDUX TOOLKIT SLICE
        // ==========================================
        
        const todoSlice = createSlice({
            name: 'todos',
            initialState: {
                items: [
                    { id: 1, text: 'Learn Redux Toolkit basics', completed: true, createdAt: new Date().toISOString() },
                    { id: 2, text: 'Create a todo slice with createSlice', completed: true, createdAt: new Date().toISOString() },
                    { id: 3, text: 'Build React components with hooks', completed: false, createdAt: new Date().toISOString() },
                    { id: 4, text: 'Test add, toggle, and remove functionality', completed: false, createdAt: new Date().toISOString() }
                ],
                filter: 'ALL' // ALL, ACTIVE, COMPLETED
            },
            reducers: {
                // Add a new todo
                addTodo: (state, action) => {
                    state.items.unshift({
                        id: Date.now() + Math.random(),
                        text: action.payload,
                        completed: false,
                        createdAt: new Date().toISOString()
                    });
                },
                
                // Toggle completion status
                toggleTodo: (state, action) => {
                    const todo = state.items.find(t => t.id === action.payload);
                    if (todo) {
                        todo.completed = !todo.completed;
                    }
                },
                
                // Remove a todo
                removeTodo: (state, action) => {
                    state.items = state.items.filter(t => t.id !== action.payload);
                },
                
                // Set filter
                setFilter: (state, action) => {
                    state.filter = action.payload;
                },
                
                // Clear all completed
                clearCompleted: (state) => {
                    state.items = state.items.filter(t => !t.completed);
                },
                
                // Edit todo text
                editTodo: (state, action) => {
                    const { id, text } = action.payload;
                    const todo = state.items.find(t => t.id === id);
                    if (todo) {
                        todo.text = text;
                    }
                }
            }
        });

        // Extract action creators automatically generated by createSlice
        const { addTodo, toggleTodo, removeTodo, setFilter, clearCompleted, editTodo } = todoSlice.actions;

        // ==========================================
        // STEP 2: CONFIGURE REDUX STORE
        // ==========================================
        
        const store = configureStore({
            reducer: {
                todos: todoSlice.reducer
            },
            devTools: true // Enable Redux DevTools Extension
        });

        // ==========================================
        // STEP 3 & 4: REACT COMPONENTS WITH HOOKS
        // ==========================================

        // --- ProgressBar Component ---
        const ProgressBar = () => {
            // useSelector: Access state from Redux store
            const todos = useSelector(state => state.todos.items);
            
            const completedCount = todos.filter(t => t.completed).length;
            const total = todos.length;
            const percentage = total === 0 ? 0 : Math.round((completedCount / total) * 100);

            return (
                <div className="mb-6">
                    <div className="flex justify-between text-sm text-gray-600 mb-2">
                        <span className="font-medium">Progress</span>
                        <span className="font-bold text-indigo-600">{percentage}%</span>
                    </div>
                    <div className="w-full bg-gray-200 rounded-full h-3 overflow-hidden">
                        <div 
                            className="progress-bar bg-gradient-to-r from-indigo-500 to-purple-500 h-full rounded-full"
                            style={{ width: `${percentage}%` }}
                        ></div>
                    </div>
                    <p className="text-xs text-gray-500 mt-1">
                        {completedCount} of {total} tasks completed
                    </p>
                </div>
            );
        };

        // --- AddTodo Component ---
        const AddTodo = () => {
            const [text, setText] = useState('');
            const inputRef = useRef(null);
            
            // useDispatch: Get dispatch function to send actions
            const dispatch = useDispatch();

            const handleSubmit = (e) => {
                e.preventDefault();
                const trimmed = text.trim();
                if (trimmed) {
                    // Dispatch addTodo action with payload
                    dispatch(addTodo(trimmed));
                    setText('');
                    inputRef.current.focus();
                }
            };

            return (
                <form onSubmit={handleSubmit} className="mb-6">
                    <div className="relative flex items-center">
                        <input
                            ref={inputRef}
                            type="text"
                            value={text}
                            onChange={(e) => setText(e.target.value)}
                            placeholder="What needs to be done?"
                            className="w-full pl-5 pr-14 py-4 bg-white border-2 border-gray-200 rounded-2xl focus:border-indigo-500 focus:outline-none text-gray-700 placeholder-gray-400 shadow-sm transition-all"
                        />
                        <button
                            type="submit"
                            disabled={!text.trim()}
                            className="absolute right-2 p-2 bg-indigo-600 hover:bg-indigo-700 disabled:bg-gray-300 text-white rounded-xl transition-colors shadow-md"
                        >
                            <i className="fas fa-plus text-lg"></i>
                        </button>
                    </div>
                </form>
            );
        };

        // --- TodoItem Component ---
        const TodoItem = ({ todo }) => {
            const [isEditing, setIsEditing] = useState(false);
            const [editText, setEditText] = useState(todo.text);
            const [isRemoving, setIsRemoving] = useState(false);
            const editRef = useRef(null);
            
            // useDispatch: Get dispatch function
            const dispatch = useDispatch();

            useEffect(() => {
                if (isEditing && editRef.current) {
                    editRef.current.focus();
                    editRef.current.select();
                }
            }, [isEditing]);

            const handleToggle = () => {
                // Dispatch toggleTodo action with todo id as payload
                dispatch(toggleTodo(todo.id));
            };

            const handleRemove = () => {
                setIsRemoving(true);
                setTimeout(() => {
                    // Dispatch removeTodo action with todo id as payload
                    dispatch(removeTodo(todo.id));
                }, 300);
            };

            const handleEdit = () => {
                if (editText.trim() && editText !== todo.text) {
                    // Dispatch editTodo action with id and new text
                    dispatch(editTodo({ id: todo.id, text: editText.trim() }));
                }
                setIsEditing(false);
            };

            const formatDate = (dateString) => {
                const date = new Date(dateString);
                return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
            };

            return (
                <div className={`todo-item slide-in flex items-center gap-3 p-4 bg-white rounded-xl shadow-sm border border-gray-100 mb-3 ${todo.completed ? 'completed bg-gray-50' : ''} ${isRemoving ? 'fade-out' : ''}`}>
                    <input
                        type="checkbox"
                        checked={todo.completed}
                        onChange={handleToggle}
                        className="checkbox-custom flex-shrink-0"
                    />
                    
                    <div className="flex-1 min-w-0">
                        {isEditing ? (
                            <input
                                ref={editRef}
                                type="text"
                                value={editText}
                                onChange={(e) => setEditText(e.target.value)}
                                onBlur={handleEdit}
                                onKeyDown={(e) => {
                                    if (e.key === 'Enter') handleEdit();
                                    if (e.key === 'Escape') {
                                        setEditText(todo.text);
                                        setIsEditing(false);
                                    }
                                }}
                                className="w-full px-2 py-1 border-2 border-indigo-300 rounded-lg focus:outline-none text-gray-700"
                            />
                        ) : (
                            <div className="flex flex-col">
                                <span 
                                    className="todo-text text-gray-800 font-medium cursor-pointer select-none truncate"
                                    onDoubleClick={() => !todo.completed && setIsEditing(true)}
                                    title="Double-click to edit"
                                >
                                    {todo.text}
                                </span>
                                <span className="text-xs text-gray-400 mt-0.5">
                                    {formatDate(todo.createdAt)}
                                </span>
                            </div>
                        )}
                    </div>

                    <div className="flex items-center gap-1 flex-shrink-0">
                        {!todo.completed && !isEditing && (
                            <button
                                onClick={() => setIsEditing(true)}
                                className="p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all"
                                title="Edit"
                            >
                                <i className="fas fa-pen text-sm"></i>
                            </button>
                        )}
                        <button
                            onClick={handleRemove}
                            className="p-2 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all"
                            title="Delete"
                        >
                            <i className="fas fa-trash-alt text-sm"></i>
                        </button>
                    </div>
                </div>
            );
        };

        // --- TodoList Component ---
        const TodoList = () => {
            // useSelector: Extract todos and filter from Redux state
            const { items: todos, filter } = useSelector(state => state.todos);
            const dispatch = useDispatch();

            // Filter todos based on current filter
            const filteredTodos = todos.filter(todo => {
                if (filter === 'ACTIVE') return !todo.completed;
                if (filter === 'COMPLETED') return todo.completed;
                return true;
            });

            if (todos.length === 0) {
                return (
                    <div className="text-center py-12">
                        <div className="w-16 h-16 bg-indigo-50 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i className="fas fa-clipboard-list text-2xl text-indigo-400"></i>
                        </div>
                        <h3 className="text-lg font-semibold text-gray-700 mb-1">No todos yet</h3>
                        <p className="text-sm text-gray-500">Add a new task above to get started!</p>
                    </div>
                );
            }

            return (
                <div className="space-y-1 min-h-[200px]">
                    {filteredTodos.length === 0 ? (
                        <div className="text-center py-12">
                            <div className="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                                <i className="fas fa-filter text-2xl text-gray-400"></i>
                            </div>
                            <h3 className="text-lg font-semibold text-gray-700 mb-1">No matching todos</h3>
                            <p className="text-sm text-gray-500">Try changing your filter to see more tasks.</p>
                        </div>
                    ) : (
                        filteredTodos.map(todo => (
                            <TodoItem key={todo.id} todo={todo} />
                        ))
                    )}
                    
                    {/* Stats & Clear */}
                    {todos.some(t => t.completed) && (
                        <div className="flex items-center justify-between mt-6 pt-6 border-t border-gray-200">
                            <p className="text-sm text-gray-500">
                                <span className="font-semibold text-gray-700">{todos.filter(t => !t.completed).length}</span> items left
                            </p>
                            <button
                                onClick={() => dispatch(clearCompleted())}
                                className="text-sm text-red-500 hover:text-red-700 hover:bg-red-50 px-3 py-1.5 rounded-lg transition-all font-medium"
                            >
                                <i className="fas fa-broom mr-1"></i>
                                Clear completed
                            </button>
                        </div>
                    )}
                </div>
            );
        };

        // --- FilterTabs Component ---
        const FilterTabs = () => {
            // useSelector: Get current filter from state
            const filter = useSelector(state => state.todos.filter);
            const todos = useSelector(state => state.todos.items);
            const dispatch = useDispatch();

            const filters = [
                { key: 'ALL', label: 'All', count: todos.length },
                { key: 'ACTIVE', label: 'Active', count: todos.filter(t => !t.completed).length },
                { key: 'COMPLETED', label: 'Completed', count: todos.filter(t => t.completed).length }
            ];

            return (
                <div className="flex gap-2 mb-6 p-1 bg-gray-100 rounded-xl">
                    {filters.map(f => (
                        <button
                            key={f.key}
                            onClick={() => dispatch(setFilter(f.key))}
                            className={`filter-btn flex-1 py-2 px-4 rounded-lg text-sm font-medium transition-all ${filter === f.key ? 'active shadow-sm' : 'text-gray-600 hover:text-gray-900'}`}
                        >
                            {f.label}
                            <span className={`ml-2 text-xs px-2 py-0.5 rounded-full ${filter === f.key ? 'bg-white/30' : 'bg-gray-200 text-gray-500'}`}>
                                {f.count}
                            </span>
                        </button>
                    ))}
                </div>
            );
        };

        // --- Main App Component ---
        const App = () => {
            return (
                <div className="max-w-2xl mx-auto">
                    {/* Header */}
                    <div className="text-center mb-8">
                        <h1 className="text-4xl font-bold text-white mb-2 drop-shadow-md">
                            <i className="fas fa-check-double mr-3"></i>
                            Redux Toolkit Todos
                        </h1>
                        <p className="text-indigo-100 text-lg">Modern state management with createSlice</p>
                    </div>

                    {/* Main Card */}
                    <div className="bg-white/95 backdrop-blur-sm rounded-3xl shadow-2xl p-6 md:p-8">
                        <ProgressBar />
                        <AddTodo />
                        <FilterTabs />
                        <TodoList />
                    </div>

                    {/* Footer */}
                    <div className="text-center mt-6 text-white/70 text-sm space-y-1">
                        <p>Built with Redux Toolkit • useSelector & useDispatch hooks</p>
                        <p className="text-xs opacity-75">Double-click to edit • Auto-generated actions from createSlice</p>
                    </div>
                </div>
            );
        };

        // ==========================================
        // RENDER WITH PROVIDER
        // ==========================================
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(
            <Provider store={store}>
                <App />
            </Provider>
        );
    </script>
</body>
</html>